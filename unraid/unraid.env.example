# Sentinel — Unraid Environment Variables
# Place this file alongside docker-compose.yml as .env

# Required — change this to a strong random password
DB_PASSWORD=changeme_use_a_strong_password

# Required — your Plex server URL
PLEX_URL=http://192.168.1.x:32400

# Required — your Plex authentication token
# Find it at: Plex Web → Settings → Troubleshooting → Get an X-Plex-Token
# Or check your existing Tautulli settings
PLEX_TOKEN=your_plex_token_here

# Optional — port to expose Sentinel on (default 7700)
SENTINEL_PORT=7700
